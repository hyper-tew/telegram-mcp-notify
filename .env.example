# Required
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Optional
# TELEGRAM_PARSE_MODE=HTML
# TELEGRAM_DISABLE_NOTIFICATION=false
# TELEGRAM_TIMEOUT_SECONDS=10
# TELEGRAM_SINGLETON_POLICY=machine_kill_old
# TELEGRAM_SINGLETON_RETRIES=5
# TELEGRAM_SINGLETON_RETRY_DELAY_SECONDS=0.2

# Data paths (defaults to ~/.telegram-mcp-notify/)
# TELEGRAM_INBOX_DB_PATH=
# TELEGRAM_LISTENER_LOG_PATH=
# TELEGRAM_SINGLETON_LOCK_DIR=
